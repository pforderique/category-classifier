# Runtime server config
MODELS_DIR=./models
DEFAULT_MODEL=
INFERENCE_DEVICE=auto
HOST=0.0.0.0
PORT=8000

# Deploy tool config (used by upload-model.sh and update-server.sh)
LOCAL_MODELS_DIR=./models
DEPLOY_GCLOUD_INSTANCE=instance_name
DEPLOY_GCLOUD_ZONE=zone
DEPLOY_GCLOUD_PROJECT=project
DEPLOY_MODELS_DIR=/opt/category-classifier/models
DEPLOY_USE_SUDO=1
# update-server.sh only (both default to values derived from DEPLOY_MODELS_DIR above)
DEPLOY_REPO_DIR=/opt/category-classifier
DEPLOY_SERVICE=category-classifier
